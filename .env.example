# --- Provider selection ---
# Choose which LLM + embeddings backend to use:
#   - huggingface  (hosted, free tier with token)
#   - ollama       (local)
#   - openai       (paid)
RAG_PROVIDER=

# --- Shared ---
RAG_RAW_DIR=data/raw
RAG_CHROMA_DIR=data/chroma
RAG_COLLECTION=rag_docs
RAG_TOP_K=4

# --- OpenAI (only if RAG_PROVIDER=openai) ---
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Hugging Face Inference API (only if RAG_PROVIDER=huggingface) ---
# Create a free HF token: https://huggingface.co/settings/tokens
# Leave empty until you paste your real token.
HUGGINGFACEHUB_API_TOKEN=

# A generally-available instruct model (you can change it):
HF_MODEL=HuggingFaceH4/zephyr-7b-beta

# Embeddings model for retrieval:
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Ollama (only if RAG_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
